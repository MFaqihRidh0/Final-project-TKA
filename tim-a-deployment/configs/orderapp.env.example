# orderapp.env.example — template environment untuk orderapp.service
# Salin jadi /etc/orderapp/orderapp.env di TIAP app VM. JANGAN commit file asli
# (berisi JWT_SECRET). Yang di-commit ke repo cukup file .example ini.

# Koneksi MongoDB → vm-db. Trailing slash penting (app pakai client["orderdb"]).
MONGO_URI=mongodb://10.0.0.13:27017/

# ⚠️ WAJIB SAMA PERSIS di vm-app1 dan vm-app2.
# Generate sekali: openssl rand -hex 32  → lalu pakai nilai yang SAMA di kedua VM.
# Kalau beda, token JWT dari app1 ditolak app2 saat LB round-robin (401 acak).
JWT_SECRET=ganti-dengan-hasil-openssl-rand-hex-32-yang-sama-di-kedua-vm

JWT_EXPIRES=86400

# Tuning Gunicorn (diubah saat eksperimen dgn Tim B)
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=sync
GUNICORN_THREADS=1
